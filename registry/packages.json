{
  "packages": [
    {
      "name": "nv",
      "aliases": [
        "@lvls/nv"
      ],
      "title": "NV",
      "description": "Пакетный менеджер NV.",
      "homepage": "https://sosiskibot.ru/nv/",
      "variants": [
        {
          "id": "nv-linux",
          "label": "Linux",
          "os": "linux",
          "default": true,
          "is_default": true,
          "install_strategy": "unix-self-binary",
          "install_root": "$HOME/.local/bin",
          "binary_name": "nv",
          "install_command": "curl -fsSL https://sosiskibot.ru/install/nv.sh | sh",
          "update_command": "nv i nv",
          "update_policy": "nv-self",
          "metadata": {
            "bootstrapPlatform": "nv-linux"
          }
        },
        {
          "id": "nv-windows",
          "label": "Windows",
          "os": "windows",
          "default": true,
          "is_default": true,
          "install_strategy": "windows-self-binary",
          "install_root": "%LOCALAPPDATA%/NV",
          "binary_name": "nv.exe",
          "install_command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"irm https://sosiskibot.ru/install/nv.ps1 | iex\"",
          "update_command": "nv i nv",
          "update_policy": "nv-self",
          "metadata": {
            "bootstrapPlatform": "nv-windows"
          }
        }
      ]
    },
    {
      "name": "neuralv",
      "aliases": [
        "@lvls/neuralv"
      ],
      "title": "NeuralV",
      "description": "Клиент защиты NeuralV.",
      "homepage": "https://neuralvv.org/",
      "variants": [
        {
          "id": "linux",
          "label": "Linux",
          "os": "linux",
          "default": true,
          "is_default": true,
          "install_strategy": "linux-desktop-unified",
          "uninstall_strategy": "linux-remove-dir",
          "install_root": "$HOME/.local/opt/NeuralV",
          "launcher_path": "bin/NeuralV",
          "binary_name": "neuralv",
          "wrapper_name": "neuralv",
          "install_command": "nv i neuralv",
          "update_command": "nv update neuralv"
        },
        {
          "id": "windows",
          "label": "Windows",
          "os": "windows",
          "default": true,
          "is_default": true,
          "install_strategy": "windows-desktop-bundle",
          "uninstall_strategy": "windows-remove-dir",
          "install_root": "%LOCALAPPDATA%/Programs/NeuralV",
          "launcher_path": "NeuralV.exe",
          "binary_name": "neuralv.exe",
          "install_command": "nv i neuralv",
          "update_command": "nv update neuralv"
        }
      ]
    }
  ]
}
